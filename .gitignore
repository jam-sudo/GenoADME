# ---------------------------------------------------------------------------
# Integrity safeguards — these are NOT here to hide files. They are here to
# refuse to commit files that would breach docs/architecture.md §4 or
# docs/scientific-integrity.md §5.
# ---------------------------------------------------------------------------

# dbGaP-restricted GTEx individual-level data must NEVER appear in this repo.
# (architecture.md §4)
data/gtex_individual/
data/gtex_dbgap/
*.gtex_individual.*

# Large local working copies of public-but-bulky data.
# Public data subsets used by GenoADME are committed under data/genotype/,
# data/eqtl/, data/pharmgkb/. Anything outside those paths is local working
# state and not committed.
data/_local/
data/_scratch/
*.vcf.gz.tbi
*.parquet
